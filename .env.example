# Copy this to .env and fill in your values
# Never commit .env to git

# Public media base URL (no trailing slash). Full image URLs in site.ts bypass folder logic.
R2_BASE_URL=https://media.stokeleads.com

# Folder inside the bucket when using relative paths with r2img()
R2_SITE_FOLDER=apexinsulationpros

# Deployed site URL (sitemap, canonical, JSON-LD)
SITE_URL=https://example.com

PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
