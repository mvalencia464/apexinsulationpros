---
// src/components/Header.astro
import { SITE } from '../config/site';
---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="header__logo">
      {SITE.brandLogoUrl ? (
        <img src={SITE.brandLogoUrl} alt={SITE.name} loading="eager" width="420" height="110" />
      ) : (
        <span class="header__wordmark">{SITE.name}</span>
      )}
    </a>

    <nav class="header__nav" aria-label="Main navigation">
      {SITE.navLinks.map(link => (
        <a href={link.href} class="header__link">{link.label}</a>
      ))}
    </nav>

    <a href={`tel:${SITE.phone.replace(/\D/g,'')}`} class="btn btn--primary header__cta">
      Call {SITE.phone}
    </a>

    <button class="header__burger" id="burger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-nav" id="mobileNav">
    {SITE.navLinks.map(link => (
      <a href={link.href} class="mobile-nav__link">{link.label}</a>
    ))}
    <a href={`tel:${SITE.phone.replace(/\D/g,'')}`} class="btn btn--primary" style="margin-top:1rem;">
      Call Now
    </a>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: linear-gradient(90deg, rgba(14, 14, 14, 0.96) 0%, rgba(20, 20, 20, 0.95) 52%, rgba(30, 30, 30, 0.94) 100%);
    border-bottom: 1px solid rgba(0, 227, 253, 0.18);
    backdrop-filter: blur(12px);
    box-shadow: 0 10px 26px rgba(0, 0, 0, 0.35);
  }

  .header::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: linear-gradient(90deg, rgba(0, 227, 253, 0.55), rgba(57, 255, 20, 0.45), rgba(255, 145, 0, 0.55));
    opacity: 0.7;
    pointer-events: none;
  }

  .header__inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }

  .header__logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.65rem;
    font-weight: 400;
    color: var(--text);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    white-space: nowrap;
    margin-right: auto;
  }

  .header__wordmark {
    display: block;
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.35rem, 3.5vw, 1.85rem);
    letter-spacing: 0.04em;
    line-height: 1;
    background: linear-gradient(90deg, var(--text) 0%, var(--accent2) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .header__logo img {
    width: clamp(130px, 16vw, 210px);
    height: auto;
    display: block;
  }

  .header__nav {
    display: flex;
    gap: 1.75rem;
  }

  .header__link {
    color: var(--muted);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s;
  }

  .header__link:hover { color: var(--text); }

  .header__link:nth-child(odd):hover { color: #00e3fd; }

  .header__link:nth-child(even):hover { color: #ff9100; }

  .header__cta { font-size: 0.72rem; padding: 0.65rem 1rem; }

  .header__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .header__burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: all 0.25s;
  }

  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: 1rem 1.5rem 1.5rem;
    background: linear-gradient(180deg, rgba(16, 16, 16, 0.98) 0%, rgba(24, 24, 24, 0.96) 100%);
    border-top: 1px solid rgba(0, 227, 253, 0.22);
  }

  .mobile-nav__link {
    color: var(--muted);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
  }

  .mobile-nav.is-open { display: flex; }

  @media (max-width: 900px) {
    .header__nav { display: none; }
    .header__cta { display: none; }
    .header__burger { display: flex; }
  }
</style>

<script>
  const burger = document.getElementById('burger');
  const mobileNav = document.getElementById('mobileNav');
  burger?.addEventListener('click', () => {
    mobileNav?.classList.toggle('is-open');
  });
  mobileNav?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => mobileNav?.classList.remove('is-open'));
  });
</script>
