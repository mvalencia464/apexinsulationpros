---
// src/components/Footer.astro
import { SITE } from '../config/site';

const footerExtraLinks = [
  { href: "/financing", label: "Financing" },
  { href: "/insurance-claims", label: "Insurance Claims" },
  { href: "/terms", label: "Terms" },
  { href: "/hiring", label: "Hiring" },
  { href: "/policy", label: "Privacy" },
] as const;

const allFooterLinks = [...SITE.navLinks, ...footerExtraLinks];
const telHref = `tel:${SITE.phone.replace(/\D/g, "")}`;
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      {SITE.brandLogoUrl ? (
        <img
          class="footer__logo"
          src={SITE.brandLogoUrl}
          alt={SITE.name}
          loading="lazy"
          width="420"
          height="110"
        />
      ) : (
        <p class="footer__wordmark">{SITE.name}</p>
      )}
      <p class="footer__tagline">{SITE.tagline}</p>
      <p class="footer__hours">{SITE.businessHours}</p>
      <p class="footer__copy">{SITE.footerText}</p>
    </div>

    <div class="footer__contact-group footer__panel footer__panel--contact" aria-label="Contact information">
      <p class="footer__heading">Contact</p>
      <div class="footer__panel-body">
        <div class="footer__contact-quick" aria-label="Quick contact">
          <a class="footer__ghost-btn" href={telHref}>Call</a>
          <a class="footer__ghost-btn" href={`mailto:${SITE.email}`}>Email</a>
          <a
            class="footer__ghost-btn"
            href={SITE.map.link}
            target="_blank"
            rel="noopener noreferrer"
          >
            Directions
          </a>
        </div>
        <div class="footer__contact" aria-label="Contact details">
          <a class="footer__contact-link" href={telHref}>{SITE.phone}</a>
          <a class="footer__contact-link" href={`mailto:${SITE.email}`}>{SITE.email}</a>
          <p class="footer__address">{SITE.address}</p>
        </div>
      </div>
    </div>

    <div class="footer__links-group footer__panel footer__panel--explore">
      <p class="footer__heading">Explore</p>
      <nav class="footer__nav" aria-label="Footer navigation">
        {allFooterLinks.map((link) => (
          <a href={link.href} class="footer__link footer__link--pill">{link.label}</a>
        ))}
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: linear-gradient(160deg, #141414 0%, #121212 55%, #1a1a1a 100%);
    padding: 2rem 0 4rem;
    border-top: 1px solid var(--border);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(0, 1fr) minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .footer__logo {
    width: clamp(130px, 16vw, 210px);
    height: auto;
    display: block;
    margin-bottom: 0.35rem;
  }

  .footer__wordmark {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.5rem, 4vw, 2rem);
    letter-spacing: 0.06em;
    color: var(--text);
    margin-bottom: 0.35rem;
    line-height: 1.1;
  }

  .footer__copy {
    font-size: 0.8rem;
    color: var(--muted);
    max-width: none;
    margin-bottom: 0;
    line-height: 1.55;
  }

  .footer__hours {
    font-size: 0.78rem;
    color: var(--accent2);
    margin-bottom: 0.45rem;
    letter-spacing: 0.04em;
  }

  .footer__tagline {
    color: var(--text);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
    letter-spacing: 0.02em;
  }

  .footer__contact {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .footer__contact-group {
    display: flex;
    flex-direction: column;
  }

  .footer__panel-body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .footer__contact-quick {
    display: none;
  }

  .footer__ghost-btn {
    box-sizing: border-box;
    color: var(--text);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    text-align: center;
    padding: 0.55rem 0.35rem;
    border-radius: 10px;
    border: 1px solid rgba(244, 244, 245, 0.22);
    background: transparent;
    transition: border-color 0.15s, color 0.15s, background-color 0.15s;
  }

  .footer__ghost-btn:hover {
    color: var(--accent2);
    border-color: rgba(0, 227, 253, 0.45);
  }

  .footer__heading {
    color: var(--text);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.45rem;
  }

  .footer__contact-link,
  .footer__address {
    color: var(--muted);
    font-size: 0.83rem;
    text-decoration: none;
    line-height: 1.5;
  }

  .footer__contact-link:hover {
    color: var(--accent2);
  }

  .footer__links-group {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.9rem;
  }

  .footer__nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.55rem 1rem;
    width: 100%;
  }

  .footer__link {
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 500;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: color 0.15s, border-color 0.15s, background-color 0.15s;
  }

  .footer__link:hover { color: var(--accent2); }

  @media (min-width: 601px) {
    .footer__link--pill {
      display: block;
      width: auto;
      max-width: none;
      padding: 0;
      border: none;
      border-radius: 0;
      background: none;
      font-size: inherit;
      letter-spacing: inherit;
    }
  }

  @media (max-width: 960px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
    }

    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 600px) {
    .footer {
      padding-bottom: 2.5rem;
    }

    .footer__inner {
      grid-template-columns: 1fr;
      text-align: left;
      gap: 0.85rem;
    }

    .footer__brand {
      text-align: center;
      margin-bottom: 0.35rem;
    }

    .footer__logo {
      margin-left: auto;
      margin-right: auto;
    }

    .footer__panel {
      border: 1px solid rgba(244, 244, 245, 0.14);
      border-radius: 14px;
      background: rgba(10, 10, 10, 0.55);
      padding: 1rem 1.05rem 1.05rem;
      width: 100%;
      box-sizing: border-box;
    }

    .footer__panel .footer__heading {
      text-align: left;
      width: 100%;
      margin-bottom: 0.65rem;
      letter-spacing: 0.14em;
      font-size: 0.68rem;
      opacity: 0.95;
    }

    .footer__panel-body {
      gap: 0.85rem;
    }

    .footer__contact-quick {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.45rem;
      width: 100%;
    }

    .footer__contact-group,
    .footer__links-group {
      align-items: stretch;
    }

    .footer__contact {
      align-items: flex-start;
      gap: 0.4rem;
    }

    .footer__links-group {
      width: 100%;
      gap: 0;
    }

    .footer__nav {
      gap: 0.5rem 0.55rem;
    }

    .footer__link--pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      min-height: 2.45rem;
      box-sizing: border-box;
      padding: 0.45rem 0.5rem;
      border-radius: 10px;
      border: 1px solid rgba(244, 244, 245, 0.2);
      background: transparent;
      color: rgba(244, 244, 245, 0.92);
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-align: center;
    }

    .footer__link--pill:hover {
      background: rgba(255, 255, 255, 0.04);
    }
  }
</style>
