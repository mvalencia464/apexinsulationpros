---
// src/components/Hero.astro
import { SITE } from '../config/site';
import { r2img } from '../lib/r2';
import HeroEstimateForm from './HeroEstimateForm.astro';

const trust = SITE.hero.trustItems;
const licenseLine =
  SITE.licenseNumber?.trim().length > 0
    ? `Licensed & Insured · ${SITE.state} Lic #${SITE.licenseNumber}`
    : "Licensed & Insured · Florida insulation contractor";
---

<section class="hero">
  <img
    class="hero__bg"
    src={r2img(SITE.hero.image)}
    alt=""
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />
  <div class="hero__overlay"></div>
  <div class="container hero__content">
    <div class="hero__left">
      <div class="hero__badges fade-up fade-up--1">
        {SITE.hero.badges.map(badge => (
          <span class="badge">{badge}</span>
        ))}
      </div>

      <h1 class="hero__heading fade-up fade-up--2">
        {SITE.hero.heading}
      </h1>

      <p class="hero__sub fade-up fade-up--3">
        {SITE.hero.subheading}
      </p>

      <div class="hero__actions fade-up fade-up--4">
        <a href={`tel:${SITE.phone.replace(/\D/g,'')}`} class="btn btn--primary">
          {SITE.hero.ctaText}
        </a>
        <a href="#services" class="btn btn--outline">
          View services →
        </a>
      </div>

      <p class="hero__license fade-up fade-up--4">
        {licenseLine}
      </p>
    </div>

    <aside class="hero__form-wrap fade-up fade-up--3">
      <HeroEstimateForm />
    </aside>
  </div>

  <div class="hero__trust-bar">
    <div class="container trust-layout">
      {trust.map((item) => (
        <div class="trust-item">
          <div class="stars">★★★★★</div>
          <p><strong>{item.value}</strong> — {item.label}</p>
          <p class="trust-item__detail">{item.detail}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 82vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background-color: var(--deep);
    background-image: linear-gradient(165deg, #1a1a1a 0%, #121212 55%, #161616 100%);
    padding-top: 5rem;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(18, 18, 18, 0.94) 0%,
      rgba(26, 26, 26, 0.88) 46%,
      rgba(0, 227, 253, 0.12) 100%
    );
    z-index: 1;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    padding-top: 2rem;
    padding-bottom: 9rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 370px;
    align-items: start;
    gap: 2rem;
  }

  .hero__left {
    max-width: 900px;
  }

  .hero__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .badge {
    background: rgba(0, 227, 253, 0.08);
    border: 1px solid var(--border);
    color: var(--accent2);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
  }

  .hero__heading {
    color: var(--text);
    margin-bottom: 1.25rem;
    text-shadow: 0 8px 26px rgba(0,0,0,0.5);
    max-width: 20ch;
  }

  .hero__sub {
    color: var(--muted);
    font-size: 1.1rem;
    font-weight: 300;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 55ch;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .hero__license {
    color: var(--muted);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    max-width: none;
  }

  .hero__form-wrap {
    position: relative;
    background:
      linear-gradient(160deg, rgba(30, 30, 30, 0.95), rgba(18, 18, 18, 0.95));
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    backdrop-filter: blur(12px);
    box-shadow: 0 22px 44px rgba(0, 0, 0, 0.45);
  }

  .hero__form-wrap::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 3px;
    border-radius: 14px 14px 0 0;
    background: linear-gradient(90deg, rgba(0, 227, 253, 0.85), rgba(255, 145, 0, 0.35));
  }

  .hero__trust-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(18, 18, 18, 0.9);
    backdrop-filter: blur(12px);
    border-top: 1px solid var(--border);
    z-index: 3;
    padding: 1.25rem 0;
  }

  .trust-layout {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
  }

  .trust-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
    min-width: 0;
  }

  .trust-item p {
    font-size: 0.78rem;
    color: var(--muted);
    letter-spacing: 0.02em;
    margin: 0;
    line-height: 1.35;
  }

  .trust-item__detail {
    font-size: 0.68rem !important;
    opacity: 0.9;
  }

  .trust-item strong {
    color: var(--text);
  }

  .stars {
    color: var(--gold);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
  }

  @media (max-width: 1080px) {
    .hero__content {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .hero__form-wrap {
      max-width: 560px;
    }
    .trust-layout {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  @media (max-width: 600px) {
    .hero {
      min-height: 75vh;
    }
    .hero__content {
      padding-bottom: 18rem;
    }
    .hero__form-wrap {
      max-width: 100%;
    }
    .trust-layout {
      grid-template-columns: 1fr;
      gap: 1rem;
      text-align: center;
    }
    .trust-item {
      align-items: center;
    }
  }
</style>
