---
// src/pages/services/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import TestimonialGrid from '../../components/TestimonialGrid.astro';
import RecentWork from '../../components/RecentWork.astro';
import { SITE } from '../../config/site';
import { r2img } from '../../lib/r2';

export function getStaticPaths() {
  return SITE.services.map(service => ({
    params: { slug: service.slug },
    props:  { service },
  }));
}

const { service } = Astro.props;

const related = SITE.services.filter(s => s.slug !== service.slug).slice(0, 3);

const pageSteps = [
  { title: "Site visit & photos", description: `We assess thermal bypasses, moisture risk, and access tied to ${service.title.toLowerCase()}.` },
  { title: "Scope & estimate", description: "You receive a clear written scope, material options, and timeline—no pressure." },
  { title: "Installation", description: "Licensed crews complete removal (if needed), install, and quality checks on depth and air barrier continuity." },
  { title: "Walkthrough", description: "We verify cleanup, answer questions, and leave care notes for your new assembly." },
];

const pageTestimonials = SITE.reviews.slice(0, 3).map((item) => ({
  name: item.name,
  city: item.city,
  text: item.text,
  rating: item.stars,
}));

const showcaseProjects = SITE.galleryProjects.slice(0, 3).map((p) => ({
  title: p.title,
  category: p.category,
  image: p.image,
}));

const serviceFaqs = [
  {
    q: `How quickly can you schedule ${service.title.toLowerCase()} in Florida?`,
    a: "Most projects begin with a short site visit. Timing depends on attic access, material lead times, weather, and whether removal or dry-down is required first.",
  },
  {
    q: "Do you help with insurance documentation after storms or water intrusion?",
    a: "Yes. We provide photos, moisture notes, and scope summaries homeowners can share with adjusters for insulation tear-out and replacement.",
  },
  {
    q: "Do you work on residential and commercial buildings?",
    a: "Yes. We install and remove insulation across single-family, multi-family, retail shells, and metal commercial structures throughout our NE, Central, and SW Florida coverage.",
  },
];
---

<BaseLayout
  title={`${service.title} | ${SITE.name} — ${SITE.city}, ${SITE.state}`}
  description={service.shortDesc}
>
  <Header />

  <main>
    <section class="service-hero" style={`background-image: url('${r2img(service.image)}')`}>
      <div class="service-hero__overlay"></div>
      <div class="container service-hero__content">
        <a href="/#services" class="breadcrumb">All services</a>
        <h1>{service.title}</h1>
        <p>{service.shortDesc}</p>
      </div>
    </section>

    <section class="section">
      <div class="container service-detail">

        <div class="service-detail__main">
          <h2>About this service</h2>
          <p class="service-detail__body">{service.fullDesc}</p>

          <h3>What's included</h3>
          <ul class="highlights">
            {service.highlights.map(h => (
              <li>{h}</li>
            ))}
          </ul>

          <div class="service-detail__panel-grid">
            <article class="detail-panel">
              <h4>Why Florida buildings need this</h4>
              <p>
                Heat, humidity, and duct leakage in hot attics drive bills and comfort complaints. This service targets
                envelope performance—not cosmetic patches—so HVAC and indoor air quality improve together.
              </p>
            </article>
            <article class="detail-panel">
              <h4>Our typical process</h4>
              <ol>
                <li>On-site assessment and thermal notes</li>
                <li>Written scope with material options</li>
                <li>Code-aware installation or controlled removal</li>
                <li>Final walkthrough and photo documentation</li>
              </ol>
            </article>
          </div>

          <h3>Frequently asked questions</h3>
          <div class="faq-list">
            {serviceFaqs.map((faq) => (
              <details class="faq-item">
                <summary>{faq.q}</summary>
                <p>{faq.a}</p>
              </details>
            ))}
          </div>

          <div class="service-detail__cta">
            <a href={`tel:${SITE.phone.replace(/\D/g,'')}`} class="btn btn--primary">
              Call {SITE.phone}
            </a>
            <a href="/#contact" class="btn btn--dark">
              Request a callback
            </a>
          </div>
        </div>

        <aside class="service-sidebar">
          <div class="sidebar-card">
            <h4>Get a free estimate</h4>
            <p>Call or email for an honest, no-pressure quote on your attic or wall project.</p>
            <a href={`tel:${SITE.phone.replace(/\D/g,'')}`} class="btn btn--primary" style="width:100%; justify-content:center; margin-top:1rem;">
              Call {SITE.phone}
            </a>
            <a href={`mailto:${SITE.email}`} class="sidebar-email">{SITE.email}</a>
          </div>

          <div class="sidebar-card sidebar-card--areas">
            <h4>Service areas</h4>
            <ul>
              {SITE.serviceAreas.map(area => <li>{area}</li>)}
            </ul>
          </div>
        </aside>

      </div>
    </section>

    {related.length > 0 && (
      <section class="section section--alt">
        <div class="container">
          <h2 style="color: var(--text); margin-bottom: 1.5rem;">Other services</h2>
          <div class="related-grid">
            {related.map(s => (
              <a href={`/services/${s.slug}`} class="related-card">
                <div>
                  <strong>{s.title}</strong>
                  <p>{s.shortDesc}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="section">
      <div class="container">
        <ProcessSteps
          steps={pageSteps}
          title="How this project works"
          subtitle="From first visit to final walkthrough, we keep insulation scopes clear and your home respected."
        />
      </div>
    </section>

    <section class="section">
      <div class="container">
        <RecentWork projects={showcaseProjects} title="Related project photos" />
      </div>
    </section>

    <section class="section section--alt">
      <div class="container">
        <TestimonialGrid testimonials={pageTestimonials} title="What homeowners say nearby" />
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  .service-hero {
    position: relative;
    min-height: 40vh;
    display: flex;
    align-items: flex-end;
    background-size: cover;
    background-position: center;
    background-color: var(--deep);
  }

  .service-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(18,18,18,0.94) 0%, rgba(18,18,18,0.52) 100%);
  }

  .service-hero__content {
    position: relative;
    z-index: 1;
    padding-bottom: 3rem;
    padding-top: 2rem;
  }

  .breadcrumb {
    display: inline-block;
    color: var(--accent2);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
    text-decoration: none;
  }

  .service-hero__content h1 {
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .service-hero__content p {
    color: var(--muted);
    font-size: 1.1rem;
    max-width: 55ch;
  }

  .service-detail {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 3rem;
    align-items: start;
  }

  @media (max-width: 900px) {
    .service-detail { grid-template-columns: 1fr; }
  }

  .service-detail__main h2 {
    color: var(--text);
    margin-bottom: 1rem;
  }

  .service-detail__main h3 {
    color: var(--text);
    margin: 2rem 0 0.75rem;
    font-size: 1.3rem;
  }

  .service-detail__body {
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .highlights li {
    color: var(--text);
    font-size: 1rem;
    padding: 0.6rem 0 0.6rem 1.15rem;
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  .highlights li::before {
    content: "";
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--accent2);
    opacity: 0.8;
    position: absolute;
    left: 0;
    top: 1rem;
  }

  .service-detail__cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .service-detail__panel-grid {
    margin-top: 1.1rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 700px) {
    .service-detail__panel-grid {
      grid-template-columns: 1fr;
    }
  }

  .detail-panel {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem;
  }

  .detail-panel h4 {
    color: var(--text);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.15rem;
    margin-bottom: 0.35rem;
  }

  .detail-panel p {
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .detail-panel ol {
    margin-left: 1.1rem;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.75;
  }

  .faq-list {
    margin-top: 0.5rem;
    display: grid;
    gap: 0.6rem;
  }

  .faq-item {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.8rem 0.95rem;
    background: rgba(255, 255, 255, 0.01);
  }

  .faq-item summary {
    cursor: pointer;
    color: var(--text);
    font-size: 0.93rem;
    font-weight: 700;
  }

  .faq-item p {
    margin-top: 0.55rem;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .service-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: sticky;
    top: 80px;
  }

  .sidebar-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    box-shadow: 0 16px 32px rgba(0,0,0,0.25);
  }

  .sidebar-card h4 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.2rem;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .sidebar-card p {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .sidebar-email {
    display: block;
    text-align: center;
    color: var(--muted);
    font-size: 0.85rem;
    margin-top: 0.75rem;
  }

  .sidebar-card--areas ul {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }

  .sidebar-card--areas li {
    font-size: 0.85rem;
    color: var(--muted);
    padding-left: 0.85rem;
    position: relative;
  }

  .sidebar-card--areas li::before {
    content: "";
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: var(--accent2);
    position: absolute;
    left: 0;
    top: 0.45rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .related-card {
    display: block;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s;
  }

  .related-card:hover {
    border-color: var(--accent2);
    transform: translateY(-2px);
  }

  .related-card strong {
    display: block;
    color: var(--text);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }

  .related-card p {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.5;
  }
</style>
