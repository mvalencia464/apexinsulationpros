---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import AboutSection from '../components/AboutSection.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import ContactSection from '../components/ContactSection.astro';
import MapSection from '../components/MapSection.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import FAQSection from '../components/FAQSection.astro';
import Footer from '../components/Footer.astro';
import SplitFeature from '../components/SplitFeature.astro';
import RecentWork from '../components/RecentWork.astro';
import { SITE } from '../config/site';

const split = SITE.splitFeature;
---

<BaseLayout>
  <Header />
  <main class="home-neon">
    <Hero />
    <ServicesGrid />
    <section class="section">
      <div class="container">
        <SplitFeature
          eyebrow={split.eyebrow}
          title={split.title}
          description={split.description}
          image={split.image}
          buttonText={split.buttonText}
          buttonHref={split.buttonHref}
        />
      </div>
    </section>
    <section class="section">
      <div class="container">
        <ProcessSteps
          steps={[...SITE.processSteps]}
          title="Our insulation process"
          subtitle="Straightforward scheduling, contained worksites, and clear communication from first visit to walkthrough."
        />
      </div>
    </section>
    <AboutSection />
    <section class="section" id="gallery">
      <div class="container">
        <RecentWork projects={[...SITE.galleryProjects]} title="Attic &amp; project gallery" />
      </div>
    </section>
    <ReviewsSection />
    <FAQSection />
    <ContactSection />
    <MapSection />
  </main>
  <Footer />
</BaseLayout>

<style>
  .home-neon {
    --accent: #ff9100;
    --accent2: #39ff14;
    --cyan: #00e3fd;
    --border: rgba(57, 255, 20, 0.28);
    --surface: #111111;
    --panel: #161616;
    --panel2: #1c1c1c;
    --muted: rgba(230, 255, 224, 0.72);
    background:
      radial-gradient(85% 55% at 15% 8%, rgba(0, 227, 253, 0.1) 0%, transparent 55%),
      radial-gradient(80% 50% at 85% 10%, rgba(255, 145, 0, 0.09) 0%, transparent 52%),
      linear-gradient(180deg, var(--deep) 0%, var(--surface) 48%, var(--deep) 100%);
  }

  .home-neon :global(.hero__overlay) {
    background: linear-gradient(
      135deg,
      rgba(10, 14, 10, 0.94) 0%,
      rgba(14, 20, 14, 0.9) 46%,
      rgba(57, 255, 20, 0.14) 86%,
      rgba(0, 227, 253, 0.1) 100%
    );
  }

  .home-neon :global(.hero__form-wrap),
  .home-neon :global(.contact__form-wrap),
  .home-neon :global(.estimate-form) {
    background: linear-gradient(160deg, rgba(22, 30, 22, 0.94), rgba(12, 16, 12, 0.94));
  }

  .home-neon :global(.hero__form-wrap::before),
  .home-neon :global(.contact__form-wrap::before) {
    background: linear-gradient(90deg, rgba(57, 255, 20, 0.85), rgba(0, 227, 253, 0.35), rgba(255, 145, 0, 0.3));
  }

  .home-neon :global(.section-label) {
    color: var(--cyan);
  }

  .home-neon :global(.section-label::before) {
    background: linear-gradient(90deg, var(--cyan), var(--accent), transparent);
  }

  .home-neon :global(.hero .badge) {
    color: #00e3fd;
    background: rgba(0, 227, 253, 0.1);
    border-color: rgba(0, 227, 253, 0.35);
    box-shadow: inset 0 0 0 1px rgba(0, 227, 253, 0.18);
  }

  .home-neon :global(.btn--outline) {
    border-color: rgba(0, 227, 253, 0.38);
    box-shadow: inset 0 0 0 1px rgba(57, 255, 20, 0.16);
  }

  .home-neon :global(.btn--outline:hover) {
    border-color: rgba(255, 145, 0, 0.55);
  }

  .home-neon :global(.btn--primary) {
    background: linear-gradient(135deg, #39ff14 0%, #84ff66 100%);
    color: #0e120e;
    border-color: rgba(57, 255, 20, 0.45);
    box-shadow: 0 10px 24px rgba(57, 255, 20, 0.2);
  }

  .home-neon :global(.btn--primary:hover) {
    background: linear-gradient(135deg, #5dff3f 0%, #9bff82 100%);
    color: #0c100c;
  }
</style>
