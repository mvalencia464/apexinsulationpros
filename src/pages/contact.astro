---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactSection from '../components/ContactSection.astro';
import TeamGrid from '../components/TeamGrid.astro';
import MapSection from '../components/MapSection.astro';
import { SITE } from '../config/site';

const teamMembers = SITE.founders.map((f) => ({
  name: f.name,
  role: f.role,
  image: f.headshot,
}));
---

<BaseLayout
  title={`Contact ${SITE.name} | Free insulation estimate`}
  description={`Contact ${SITE.name} for spray foam, blown-in, removal, radiant barriers, and insurance-driven reinsulation across Northeast, Central, and Southwest Florida.`}
>
  <Header />

  <main>
    <section class="section contact-hero">
      <div class="container">
        <span class="section-label">Contact</span>
        <h1>Talk to an insulation specialist</h1>
        <p>
          Call for same-week scheduling in many markets, or send a project summary. We serve Jacksonville, Orlando,
          Tampa, St Augustine, and surrounding areas with clear scopes and no call-center runaround.
        </p>
        <div class="contact-hero__actions">
          <a href={`tel:${SITE.phone.replace(/\D/g, '')}`} class="btn btn--primary">Call {SITE.phone}</a>
          <a href={`mailto:${SITE.email}`} class="btn btn--outline">Email {SITE.email}</a>
        </div>
      </div>
    </section>

    <ContactSection />

    <section class="section section--alt">
      <div class="container">
        <TeamGrid members={teamMembers} title="Meet the founders" />
      </div>
    </section>

    <MapSection />
  </main>

  <Footer />
</BaseLayout>

<style>
  .contact-hero {
    padding-top: 8rem;
  }

  .contact-hero h1 {
    color: var(--text);
    margin-bottom: 0.7rem;
  }

  .contact-hero p {
    color: var(--muted);
    font-size: 1.03rem;
    line-height: 1.7;
    max-width: 68ch;
  }

  .contact-hero__actions {
    margin-top: 1.1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }
</style>
